generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Engine {
  id         String   @id @default(cuid())
  name       String   @unique
  kind       String
  createdAt  DateTime @default(now())
  whiteGames Game[]   @relation("WhiteEngineGames")
  blackGames Game[]   @relation("BlackEngineGames")
}

model Game {
  id            String        @id @default(cuid())
  benchmarkId   String?
  whiteEngineId String
  blackEngineId String
  result        String?
  status        String
  finalFen      String?
  pgn           String?
  moveCount     Int           @default(0)
  startedAt     DateTime      @default(now())
  endedAt       DateTime?
  whiteEngine   Engine        @relation("WhiteEngineGames", fields: [whiteEngineId], references: [id])
  blackEngine   Engine        @relation("BlackEngineGames", fields: [blackEngineId], references: [id])
  benchmark     BenchmarkRun? @relation(fields: [benchmarkId], references: [id])
  moves         Move[]
}

model Move {
  id        String   @id @default(cuid())
  gameId    String
  ply       Int
  san       String
  from      String
  to        String
  fenAfter  String
  evalAfter Int?
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, ply])
}

model BenchmarkRun {
  id              String    @id @default(cuid())
  whiteEngine     String
  blackEngine     String
  totalGames      Int
  completedGames  Int       @default(0)
  winsWhite       Int       @default(0)
  winsBlack       Int       @default(0)
  draws           Int       @default(0)
  averagePlyCount Float     @default(0)
  swapColors      Boolean   @default(false)
  isRunning       Boolean   @default(false)
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  games           Game[]
}
